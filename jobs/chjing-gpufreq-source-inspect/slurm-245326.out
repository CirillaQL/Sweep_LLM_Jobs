# Find dependencies
find_package(SLURM REQUIRED)
find_package(CUDAToolkit REQUIRED)

# Add directories
add_subdirectory(src)
===== file_head /data/users/chjing/test_nvgpufreq.sh =====
#!/bin/bash
#SBATCH --job-name=test_nvgpufreq
#SBATCH --gres=gpu:L40s:1
#SBATCH --gres=nvgpufreq
#SBATCH --exclusive
#SBATCH --nodelist=neptune
#SBATCH --nodes=1
#SBATCH --time=00:05:00
#SBATCH --output=test_nvgpufreq_%j.out

echo "=========================================="
echo "Testing nvgpufreq plugin"
echo "=========================================="
echo "Node: $(hostname)"
echo "Job ID: $SLURM_JOB_ID"
echo ""

# Check if plugin activated
if [ -f /var/run/nvgpufreq.run ]; then
    echo "✓ Plugin activated successfully!"
    echo "Plugin status:"
    cat /var/run/nvgpufreq.run
else
    echo "✗ Plugin status file not found"
fi

echo ""
echo "=========================================="
echo "Showing supported GPU frequencies:"
echo "=========================================="
nvidia-smi -q -d SUPPORTED_CLOCKS

echo ""
echo "=========================================="
echo "Current GPU frequency:"
echo "=========================================="
nvidia-smi -q -d CLOCK

echo ""
echo "=========================================="
echo "Attempting to set GPU frequency:"
echo "=========================================="
# Try to set a frequency (adjust based on your GPU's supported values)
nvidia-smi -i 0 --applications-clocks=9001,2400 2>&1

echo ""
echo "Verification after setting:"
nvidia-smi -q -d CLOCK

echo ""
echo "Test complete!"


