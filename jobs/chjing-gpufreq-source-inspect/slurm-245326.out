===== file_head /data/users/chjing/measure_dvfs.cu =====
#include <iostream>
#include <vector>
#include <chrono>
#include <thread>
#include <numeric>
#include <iomanip>
#include <cmath>

#include <cuda_runtime.h>
#include <nvml.h>

// --- Error Checking Macros ---
#define CUDA_SAFE_CALL(x)                                             \
    do                                                                \
    {                                                                 \
        cudaError_t err = x;                                          \
        if (err != cudaSuccess)                                       \
        {                                                             \
            fprintf(stderr, "CUDA error in %s:%d: %s\n", __FILE__, __LINE__, cudaGetErrorString(err)); \
            exit(1);                                                  \
        }                                                             \
    } while (0)

#define NVML_SAFE_CALL(x)                                             \
    do                                                                \
    {                                                                 \
        nvmlReturn_t err = x;                                         \
        if (err != NVML_SUCCESS)                                      \
        {                                                             \
            fprintf(stderr, "NVML error in %s:%d: %s\n", __FILE__, __LINE__, nvmlErrorString(err)); \
            exit(1);                                                  \
        }                                                             \
    } while (0)


__global__ void spin_kernel(long long cycles) {
    long long start = clock64();
    long long end = start + cycles;
    while (clock64() < end);
}

void set_gpu_clocks(nvmlDevice_t device, unsigned int sm_clock, unsigned int mem_clock) {
    // Suppress cout for cleaner measurement output
    // std::cout << "Setting clocks to SM=" << sm_clock << " MHz, MEM=" << mem_clock << std::endl;
    NVML_SAFE_CALL(nvmlDeviceSetApplicationsClocks(device, mem_clock, sm_clock));
}

void reset_gpu_clocks(nvmlDevice_t device) {
    std::cout << "Resetting clocks to default." << std::endl;
    NVML_SAFE_CALL(nvmlDeviceResetApplicationsClocks(device));
}

double measure_average_kernel_time(long long spin_cycles, int samples) {
    double total_time_ms = 0;
    for (int i = 0; i < samples; ++i) {
        cudaEvent_t start, stop;
        CUDA_SAFE_CALL(cudaEventCreate(&start));
        CUDA_SAFE_CALL(cudaEventCreate(&stop));
        CUDA_SAFE_CALL(cudaEventRecord(start));
        spin_kernel<<<1, 1>>>(spin_cycles);
        CUDA_SAFE_CALL(cudaEventRecord(stop));
        CUDA_SAFE_CALL(cudaEventSynchronize(stop));
        float ms = 0;
        CUDA_SAFE_CALL(cudaEventElapsedTime(&ms, start, stop));
        total_time_ms += ms;
        CUDA_SAFE_CALL(cudaEventDestroy(start));
        CUDA_SAFE_CALL(cudaEventDestroy(stop));
    }
    return total_time_ms / samples;
}

int main(int argc, char** argv) {
    if (argc != 4) {
        std::cerr << "Usage: " << argv[0] << " <from_freq_mhz> <to_freq_mhz> <mem_freq_mhz>" << std::endl;
        return 1;
    }

    unsigned int from_freq = std::stoi(argv[1]);
    unsigned int to_freq = std::stoi(argv[2]);
    unsigned int mem_freq = std::stoi(argv[3]);
    int device_id = 0;

    NVML_SAFE_CALL(nvmlInit());
    nvmlDevice_t device;
    NVML_SAFE_CALL(nvmlDeviceGetHandleByIndex(device_id, &device));
    CUDA_SAFE_CALL(cudaSetDevice(device_id));

    const long long spin_cycles = 400000; // Keep kernel very short for high resolution

    std::cout << "\n--- Establishing Baselines ---" << std::endl;
    set_gpu_clocks(device, to_freq, mem_freq);
    std::this_thread::sleep_for(std::chrono::milliseconds(200));
    double baseline_target_time_ms = measure_average_kernel_time(spin_cycles, 100);
    std::cout << "Baseline time at " << to_freq << " MHz: " << std::fixed << std::setprecision(6) 
              << baseline_target_time_ms << " ms" << std::endl;

    std::cout << "\n--- Preparing for Measurement ---" << std::endl;
    set_gpu_clocks(device, from_freq, mem_freq);
    std::this_thread::sleep_for(std::chrono::milliseconds(200));
    
    std::cout << "\n--- Measuring Transition ---" << std::endl;
    
    // ***************************************************************
    // *****         NEW ASYNCHRONOUS PROBING METHOD             *****
    // ***************************************************************
    
    const int num_probes = 1000;
    std::vector<cudaEvent_t> start_events(num_probes);
    std::vector<cudaEvent_t> stop_events(num_probes);
    for(int i = 0; i < num_probes; ++i) {
        CUDA_SAFE_CALL(cudaEventCreate(&start_events[i]));
        CUDA_SAFE_CALL(cudaEventCreate(&stop_events[i]));
    }

    CUDA_SAFE_CALL(cudaDeviceSynchronize()); // Ensure device is idle

    // ISSUE THE DVFS COMMAND
    auto cpu_start = std::chrono::high_resolution_clock::now();
    set_gpu_clocks(device, to_freq, mem_freq);

    // Immediately launch all probe kernels asynchronously
    for (int i = 0; i < num_probes; ++i) {
        CUDA_SAFE_CALL(cudaEventRecord(start_events[i]));
        spin_kernel<<<1, 1>>>(spin_cycles);
        CUDA_SAFE_CALL(cudaEventRecord(stop_events[i]));
    }
    
    // Wait for all probes to complete
    CUDA_SAFE_CALL(cudaDeviceSynchronize());
    auto cpu_end = std::chrono::high_resolution_clock::now();
    
    // --- Analyze the results ---
    std::vector<float> durations_ms(num_probes);
    for (int i = 0; i < num_probes; ++i) {
        CUDA_SAFE_CALL(cudaEventElapsedTime(&durations_ms[i], start_events[i], stop_events[i]));
    }

    double transition_duration_us = 0;
    const double tolerance = 0.05; // 5% tolerance is fine for this method
    // int stable_count = 0;
    const int stable_threshold = 5; // Require 5 stable probes for confidence

    for (int i = 0; i < num_probes - stable_threshold; ++i) {
        bool is_stable = true;
        for (int j = 0; j < stable_threshold; ++j) {
            if (std::abs(durations_ms[i+j] - baseline_target_time_ms) / baseline_target_time_ms > tolerance) {
                is_stable = false;
                break;
            }
        }

        if (is_stable) {
            // Found the first stable probe. The transition is complete.
            // Calculate total time up to the END of this first stable probe.
            // float total_time_ms = 0;
            // for (int k = 0; k <= i; ++k) {
            //     total_time_ms += durations_ms[k];
            // }
            // transition_duration_us = total_time_ms * 1000.0;
            // std::cout << "Stabilized at probe " << i << ". Kernel time: " << durations_ms[i] << " ms" << std::endl;
            
            float span_ms = 0;
            CUDA_SAFE_CALL(cudaEventElapsedTime(&span_ms, start_events[0], stop_events[i]));
            transition_duration_us = span_ms * 1000.0;
            //std::cout << "Stabilized at probe " << i << std::endl;
            break;
        }
    }

    // --- Cleanup ---
    for(int i = 0; i < num_probes; ++i) {
        CUDA_SAFE_CALL(cudaEventDestroy(start_events[i]));
        CUDA_SAFE_CALL(cudaEventDestroy(stop_events[i]));
    }
    reset_gpu_clocks(device);
    NVML_SAFE_CALL(nvmlShutdown());
    
    std::cout << "\n==============================================" << std::endl;
    if (transition_duration_us == 0) {
        std::cout << "✗ Warning: Could not detect a stable transition within " << num_probes << " probes." << std::endl;
    }
    std::cout << "DVFS Transition Time (" << from_freq << " -> " << to_freq << " MHz): " 
              << std::fixed << std::setprecision(2) << transition_duration_us << " us" << std::endl;
    std::cout << "=============================================\n" << std::endl;

    return 0;
}

