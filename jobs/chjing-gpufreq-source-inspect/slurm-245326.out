#!/bin/bash
echo "Node: $(hostname)"
echo "Job ID: $SLURM_JOB_ID"

if [ -f /var/run/nvgpufreq.run ]; then
    echo "✓ Plugin activated"
    cat /var/run/nvgpufreq.run
else
    echo "✗ Plugin not activated"
fi

nvidia-smi -q -d SUPPORTED_CLOCKS | head -50
nvidia-smi -i 0 --applications-clocks=9001,2400 2>&1
nvidia-smi -q -d CLOCK | head -30

===== file_head /data/users/chjing/measure_dvfs_transition.sh =====
#!/bin/bash

# nvcc measure_dvfs.cu -o measure_dvfs -lnvidia-ml


# L4 Configuration
# MAX_FREQ=2040
# MEM_FREQ=6251
# STEP=90
# MIN_FREQ=210  # Adjust based on your GPU's limit

# L40s Configuration
MAX_FREQ=2520
MEM_FREQ=9001
STEP=105
MIN_FREQ=210  # Adjust based on your GPU's limit

ITERATIONS=80 # 50 samples is usually enough to find a stable median

OUTPUT_FILE="L40S_down_dvfs_latency.csv"

# Initialize CSV file with headers
echo "Delta_MHz,Target_Freq_MHz,Latency_us" > $OUTPUT_FILE

echo "Starting Benchmark..."
echo "Config: Max=$MAX_FREQ, Step=$STEP, Iterations=$ITERATIONS"

# Loop from MAX down to MIN
# We start slightly below MAX because measuring 2040->2040 is 0
current_target=$((MAX_FREQ - 15)) # Example start point

while [ $current_target -ge $MIN_FREQ ]
do
    delta=$((MAX_FREQ - current_target))
    
    echo "Measuring Delta: ${delta} MHz (Target: ${current_target} MHz)..."
    
    for (( i=1; i<=ITERATIONS; i++ ))
    do
        # Run the C++ program
        # We capture the output and extract the specific line with "DVFS Transition Time"
        output=$(sudo ./measure_dvfs $MAX_FREQ $current_target $MEM_FREQ)
        
        # Parse the latency value (us) using grep and awk
        # Assumes output format: "DVFS Transition Time (...): 1234.56 us"
        latency=$(echo "$output" | grep "DVFS Transition Time" | awk '{print $(NF-1)}')
        
        # Check if we got a valid number
        if [[ -n "$latency" ]]; then
            echo "$delta,$current_target,$latency" >> $OUTPUT_FILE
        else
            echo "Error reading latency for run $i"
        fi
        
        # Short sleep to allow GPU state to settle (prevents thermal throttling buildup)
        sleep 1 
    done

    # Decrease frequency
    current_target=$((current_target - STEP))
done

echo "Done! Data saved to $OUTPUT_FILE"

# Upscaling Benchmark Script
# Initialize CSV file with headers
# We log Start_Freq because Target is always MAX_FREQ
OUTPUT_FILE="L40S_up_dvfs_latency.csv"
echo "Delta_MHz,Start_Freq_MHz,Latency_us" > $OUTPUT_FILE

echo "Starting Upscaling Benchmark..."
echo "Config: Target Fixed at $MAX_FREQ, Sweeping Start from $MIN_FREQ to Max"

# Start from the bottom (MIN_FREQ) and go UP
current_start=$MIN_FREQ

# Loop until we get close to Max Freq
while [ $current_start -lt $MAX_FREQ ]
do
    delta=$((MAX_FREQ - current_start))
    
    echo "Measuring Delta: ${delta} MHz (Transition: ${current_start} -> ${MAX_FREQ})..."
    
    for (( i=1; i<=ITERATIONS; i++ ))
    do
        # COMMAND CHANGE: 
        # Arg 1 (From) is variable: $current_start
        # Arg 2 (To)   is fixed:    $MAX_FREQ
        output=$(sudo ./measure_dvfs $current_start $MAX_FREQ $MEM_FREQ)
        
        # Parse the latency
        latency=$(echo "$output" | grep "DVFS Transition Time" | awk '{print $(NF-1)}')
        
        # Save to CSV
        if [[ -n "$latency" ]]; then
            echo "$delta,$current_start,$latency" >> $OUTPUT_FILE
        else
            echo "Error reading latency for run $i"
        fi
        
        # Short sleep to reset thermal state
        sleep 1 
    done

    # LOGIC CHANGE: Increment the start frequency
    current_start=$((current_start + STEP))
done

echo "Done! Data saved to $OUTPUT_FILE"


# Tiny Change (PLL Lock): 2040 -> 2025 (You've done this)
# Small Change: 2040 -> 1980
# Small-Medium Change: 2040 -> 1800
# Medium Change: 2040 -> 1500
# Medium-Large Change: 2040 -> 1005 (You've done this)
# Large Change: 2040 -> 615
# Extreme Change (Max Voltage Drop): 2040 -> 210 (You've done this)

# Step 4 (Optional Advanced): Finding the "Knee"
# The most interesting part of the cost curve is the point where it transitions from cheap (sub-500µs) to expensive (milliseconds). This "knee" represents the boundary of a voltage plane. You can find it by doing a fine-grained sweep.
# Run a sweep to find the boundary:
# Measure 2040 -> F for F from 2025 down to 1800 in 15 MHz increments.
# Plot the results. You will likely see a clear point where the cost suddenly jumps up. This tells you the maximum frequency drop you can get "for free" without a slow voltage change.

############# L4 DVFS Transition Measurements #############
# for i in {0..11}
# do
#     # Ramping down from max frequency to min frequency in steps of 90 MHz, in total 20 steps
#     sudo ./measure_dvfs 2040 2025 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1935 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1845 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1755 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1665 6251
#     sleep 2     
#     sudo ./measure_dvfs 2040 1575 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1485 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1395 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1305 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1215 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1125 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 1035 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 945 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 855 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 765 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 675 6251
#     sleep 2 
#     sudo ./measure_dvfs 2040 585 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 495 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 405 6251
#     sleep 2
#     sudo ./measure_dvfs 2040 315 6251
#     sleep 2
