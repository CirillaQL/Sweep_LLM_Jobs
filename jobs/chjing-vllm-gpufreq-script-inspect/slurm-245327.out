----- head /data/users/chjing/vLLM_test/submit_experiment_A_highfreq_probe.sh -----
#!/bin/bash
# Focused Experiment A rerun for workload (1024,128,r=10).
#
# Submit directly:
#   sbatch submit_experiment_A_highfreq_probe.sh
#
# This runs the full Experiment A config set for workload (1024,128,r=10)
# twice on neptune, writing each repeat into a separate results directory so
# the current completed A dataset remains untouched.

#SBATCH --job-name=jsep_A_highfreq_probe
#SBATCH --partition=long
#SBATCH --nodes=1
#SBATCH --ntasks=8
#SBATCH --ntasks-per-node=8
#SBATCH --nodelist=neptune
#SBATCH --exclusive
#SBATCH --mem=0
#SBATCH --time=23:59:59
#SBATCH --output=logs/disagg_A_highfreq_probe_%j.log

set -euo pipefail

SCRIPT_DIR="${SLURM_SUBMIT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

export EXP="A"
export L40S_NODE="${L40S_NODE:-neptune}"
export NUM_PROMPTS="${NUM_PROMPTS:-200}"
export NUM_WARMUPS="${NUM_WARMUPS:-1}"
export RESULT_DIR_BASE="${RESULT_DIR_BASE:-results/disagg_20260405_A_1024x128_neptune_repeat}"
export L40S_CONFIGS="${L40S_CONFIGS:-1245:1 1500:1 1755:1 2010:1 2265:1 2520:1 1500:2 2010:2 2520:2 1500:4 2010:4 2520:4}"
export WORKLOADS_OVERRIDE="${WORKLOADS_OVERRIDE:-1024 128 10 64}"

echo "Focused Experiment A full-set probe for workload (1024,128,r=10)"
echo "  SLURM_JOB_NODELIST=${SLURM_JOB_NODELIST:-<unset>}"
echo "  L40S_NODE=${L40S_NODE}"
echo "  RESULT_DIR_BASE=${RESULT_DIR_BASE}"
echo "  NUM_PROMPTS=${NUM_PROMPTS}"
echo "  NUM_WARMUPS=${NUM_WARMUPS}"
echo "  L40S_CONFIGS=${L40S_CONFIGS}"
echo "  WORKLOADS_OVERRIDE=${WORKLOADS_OVERRIDE}"

for repeat in 1 2; do
    export RESULT_DIR="${RESULT_DIR_BASE}_r${repeat}"
    echo ""
    echo "=== Repeat ${repeat}: RESULT_DIR=${RESULT_DIR} ==="
    L40S_NODE="${L40S_NODE}" RESULT_DIR="${RESULT_DIR}" bash "${SCRIPT_DIR}/run_disagg_benchmark.sh"
done

