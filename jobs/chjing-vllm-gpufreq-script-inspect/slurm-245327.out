#!/bin/bash
#SBATCH --job-name=vllm_calibration
#SBATCH --nodelist=uranus
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --output=vllm_calibration_%j.out
#SBATCH --error=vllm_calibration_%j.err

# ==============================================================================
# 1. GLOBAL CONFIGURATION
# ==============================================================================
# vLLM Configuration
MODEL="mistralai/Mistral-7B-v0.1"
PORT=8000
VLLM_LOG="vllm_server.log"

# Environment Setup
export CUDA_VISIBLE_DEVICES=0
GPU_ID=0

# L40S - 10 evenly spaced frequencies from 2520 to 210 MHz
SUPPORTED_MEM_FREQUENCIES=("9001")
GPU_FREQ=("2520" "2265" "2010" "1755" "1500" "1245" "990" "735" "480" "210")

# ==============================================================================
# 2. OUTPUT SETUP
# ==============================================================================
OUTPUT_DIR="vLLM_Calibration_Results"
mkdir -p "$OUTPUT_DIR"
RESULTS_SUMMARY="$OUTPUT_DIR/calibration_summary.csv"
echo "CASE,MEM_FREQ,GPU_FREQ,KERNEL_START_MS,KERNEL_END_MS,DURATION_MS" > "$RESULTS_SUMMARY"

# ==============================================================================
# 3. MONITORING SETUP (from gpu_monitor.py)
# ==============================================================================
MONITOR_SCRIPT="gpu_monitor.py"
MONITOR_PIDS=()

cleanup_monitors() {
    echo "--- Cleanup monitors ---"
    if [ ${#MONITOR_PIDS[@]} -eq 0 ]; then
        return
    fi

    for PID in "${MONITOR_PIDS[@]}"; do
        if kill -0 "$PID" 2>/dev/null; then
            kill -TERM "$PID" 2>/dev/null || true
        fi
    done

    for attempt in {1..10}; do
        all_dead=true
        for PID in "${MONITOR_PIDS[@]}"; do
            if kill -0 "$PID" 2>/dev/null; then
                all_dead=false
                break
            fi
        done
        if $all_dead; then
            break
        fi
        sleep 0.5
    done

    for PID in "${MONITOR_PIDS[@]}"; do
        if kill -0 "$PID" 2>/dev/null; then
            kill -KILL "$PID" 2>/dev/null || true
        fi
    done

    MONITOR_PIDS=()
    sync
    sleep 1
}

cleanup_all() {
    echo "--- Full cleanup ---"
    cleanup_monitors
    if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Shutting down vLLM server (PID: $SERVER_PID)..."
        kill "$SERVER_PID"
        wait "$SERVER_PID" 2>/dev/null
    fi
}

trap cleanup_all EXIT INT TERM

# ==============================================================================
# 4. START vLLM SERVER
# ==============================================================================
ulimit -n 65536

echo "Python version: $(python --version)"
echo "vLLM version: $(python -c 'import vllm; print(vllm.__version__)')"
echo "CUDA available: $(python -c 'import torch; print(torch.cuda.is_available())')"
echo "==========================================="

echo "Starting vLLM server..."
echo "Model: $MODEL"
echo "Port: $PORT"

python -m vllm.entrypoints.openai.api_server \
  --model $MODEL \
  --host localhost \
  --port $PORT \
  --tensor-parallel-size 1 \
  > $VLLM_LOG 2>&1 &

SERVER_PID=$!
echo "vLLM server started with PID: $SERVER_PID"

# Wait for server to be ready
echo "Waiting for server to be ready..."
MAX_WAIT=600
ELAPSED=0
while ! curl -s http://localhost:$PORT/v1/models > /dev/null; do
    sleep 10
    ELAPSED=$((ELAPSED + 10))
    if [ $((ELAPSED % 30)) -eq 0 ]; then
        echo "--- Last 5 lines of server log ---"
        tail -n 5 $VLLM_LOG
        echo "-----------------------------------"
    fi
    if ! ps -p $SERVER_PID > /dev/null; then
        echo "ERROR: Server process died!"
        cat $VLLM_LOG
        exit 1
    fi
    if [ $ELAPSED -ge $MAX_WAIT ]; then
        echo "Server failed to start within $MAX_WAIT seconds"
        kill $SERVER_PID
        exit 1
    fi
    echo "Waiting... ($ELAPSED seconds)"
done
echo "Server is ready!"
echo "==========================================="

# ==============================================================================
# 5. MAIN CALIBRATION LOOP
# ==============================================================================
for MEM_FREQ in "${SUPPORTED_MEM_FREQUENCIES[@]}"; do
    for FREQ in "${GPU_FREQ[@]}"; do
        echo ""
        echo "============================================================"
        echo "Setting GPU Frequency: Mem=${MEM_FREQ} MHz, GPU=${FREQ} MHz"
        echo "============================================================"

        sudo -E $(which python3) "$MONITOR_SCRIPT" --gpu-id $GPU_ID --set-freq --gpu-freq "$FREQ" --mem-freq "$MEM_FREQ"

        if [ $? -ne 0 ]; then
            echo "  ERROR: Failed to set frequency. Skipping."
            continue
        fi

        sleep 2

        # Verify application clocks
        APP_GPU_FREQ=$(nvidia-smi -i $GPU_ID --query-gpu=clocks.applications.graphics --format=csv,noheader,nounits)
        APP_MEM_FREQ=$(nvidia-smi -i $GPU_ID --query-gpu=clocks.applications.memory --format=csv,noheader,nounits)
        if [ -n "$APP_GPU_FREQ" ] && [ -n "$APP_MEM_FREQ" ]; then
            echo "  Verified: GPU ${APP_GPU_FREQ} MHz, Memory ${APP_MEM_FREQ} MHz"
        else
            echo "  Warning: Unable to verify application clocks."
        fi

        # ----------------------------------------------------------------------
        # Case 1: Short prompts, high request rate
        # ----------------------------------------------------------------------
        echo "--- Case 1: Short prompts, high request rate ---"

        MONITOR_PIDS=()
        LOG_FILE="$OUTPUT_DIR/power_case1_${MEM_FREQ}_${FREQ}.csv"

        $(which python3) "$MONITOR_SCRIPT" --monitor --interval 0.01 --output "$LOG_FILE" --gpu-id $GPU_ID &
        PID=$!
        MONITOR_PIDS+=($PID)

        # Wait for monitor to initialize
        for k in {1..20}; do
            if [ -f "$LOG_FILE" ] && [ -s "$LOG_FILE" ]; then
                break
            fi
            sleep 0.5
        done

        if ! kill -0 $PID 2>/dev/null; then
            echo "  ERROR: Power monitor failed to start."
            continue
        fi

        # Capture start timestamp (epoch milliseconds, same format as chrono)
        START_MS=$(date +%s%3N)
        echo "KERNEL_START_TIMESTAMP:${START_MS}"

        CASE1_OUTPUT="$OUTPUT_DIR/case1_bench_${MEM_FREQ}_${FREQ}.txt"
        vllm bench serve \
          --backend openai \
          --base-url http://localhost:$PORT \
          --model $MODEL \
          --num-prompts 2000 \
          --request-rate 14 \
          --dataset-name random \
          --input-len 128 \
          --output-len 128 \
          --max-concurrency 128 \
          | tee "$CASE1_OUTPUT"

        END_MS=$(date +%s%3N)
        echo "KERNEL_END_TIMESTAMP:${END_MS}"
        DURATION=$((END_MS - START_MS))
        echo "  Case 1 duration: ${DURATION} ms"
        echo "case1,${MEM_FREQ},${FREQ},${START_MS},${END_MS},${DURATION}" >> "$RESULTS_SUMMARY"

        cleanup_monitors
        sleep 5

        # ----------------------------------------------------------------------

