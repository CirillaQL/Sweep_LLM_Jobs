----- phase2_highrate_l4.sh set/reset excerpt -----
cleanup_all() {
    echo "--- Full cleanup ---"
    cleanup_monitors
    if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Shutting down vLLM server (PID: $SERVER_PID)..."
        kill "$SERVER_PID"
        wait "$SERVER_PID" 2>/dev/null
    fi
    echo "Resetting GPU clocks..."
    sudo nvidia-smi -rac 2>/dev/null || true
}

trap cleanup_all EXIT INT TERM

start_server() {
    local tp_degree=$1

    if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Stopping existing server (PID: $SERVER_PID)..."
        kill "$SERVER_PID" 2>/dev/null || true
        wait "$SERVER_PID" 2>/dev/null || true
    fi
    pkill -TERM -u "$USER" -f "vllm" 2>/dev/null || true
    sleep 5
    pkill -KILL -u "$USER" -f "vllm" 2>/dev/null || true
    for _pid in $(nvidia-smi --query-compute-apps=pid --format=csv,noheader 2>/dev/null \
                  | grep -Ev '^$|^pid'); do
        _owner=$(ps -o user= -p "$_pid" 2>/dev/null | tr -d ' ')
        if [ "$_owner" = "$USER" ]; then
            echo "  GPU-holder kill: PID $_pid"
            kill -KILL "$_pid" 2>/dev/null || true
        fi
    done

    local gpu_wait=0
    while [ "$(nvidia-smi --query-compute-apps=pid --format=csv,noheader 2>/dev/null \
               | grep -Evc '^$|^pid')" -gt 0 ]; do
        sleep 2
        gpu_wait=$((gpu_wait + 2))
        if [ $gpu_wait -ge 30 ]; then
            echo "WARNING: GPU compute context still held after 30s; force-killing."
            for _pid in $(nvidia-smi --query-compute-apps=pid --format=csv,noheader 2>/dev/null \
                          | grep -Ev '^$|^pid'); do
                kill -KILL "$_pid" 2>/dev/null || true
            done
            sleep 5
            break
        fi
    done
    sleep 5

    local port_wait=0
    while lsof -i:$PORT -sTCP:LISTEN -t >/dev/null 2>&1; do
        sleep 2
        port_wait=$((port_wait + 2))
        if [ $port_wait -ge 30 ]; then
            echo "WARNING: Port $PORT still in use after 30s; force-killing holders."
            lsof -i:$PORT -sTCP:LISTEN -t | xargs -r kill -KILL 2>/dev/null || true
            sleep 3
            break
        fi
    done

    local gpu_list=""
    for ((g=0; g<tp_degree; g++)); do
        if [ -n "$gpu_list" ]; then gpu_list+=","; fi
        gpu_list+="$g"
    done
    export CUDA_VISIBLE_DEVICES="$gpu_list"

    echo "Starting vLLM server: model=$MODEL, TP=$tp_degree, GPUs=$gpu_list"

    python -m vllm.entrypoints.openai.api_server \
        --model $MODEL \
        --host localhost \
        --port $PORT \
        --tensor-parallel-size $tp_degree \
        --max-model-len 9216 \
        --disable-log-requests \
        > $VLLM_LOG 2>&1 &

    SERVER_PID=$!
    echo "Server PID: $SERVER_PID"

    local max_wait=600
    local elapsed=0
    while ! curl -s http://localhost:$PORT/v1/models > /dev/null 2>&1; do
        sleep 10
        elapsed=$((elapsed + 10))
        if ! ps -p $SERVER_PID > /dev/null 2>&1; then
            echo "ERROR: Server died! Last log lines:"
            tail -20 $VLLM_LOG
            exit 1
        fi
        if [ $elapsed -ge $max_wait ]; then
            echo "ERROR: Server failed to start within ${max_wait}s"
            kill $SERVER_PID 2>/dev/null
            exit 1
        fi
        echo "  Waiting for server... (${elapsed}s)"
    done
    echo "Server ready!"
}

set_gpu_freq() {
    local freq=$1
    local tp=$2
    echo "  Setting GPU frequency to ${freq} MHz (mem: ${SUPPORTED_MEM_FREQ} MHz) on $tp GPU(s)..."
    for ((g=0; g<tp; g++)); do
        sudo nvidia-smi -i $g -ac "${SUPPORTED_MEM_FREQ},${freq}"
    done
    sleep 2
}

